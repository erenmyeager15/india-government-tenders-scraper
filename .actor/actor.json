{
    "actorSpecification": 1,
    "name": "india-government-tenders-scraper",
    "title": "India Government Tenders Scraper - GeM Listings",
    "description": "Scrape public Indian government tender listings from GeM bid listings, with guarded CPPP handling when the public listing is CAPTCHA-gated.",
    "version": "1.0",
    "categories": ["BUSINESS", "AUTOMATION", "OTHER"],
    "categoriesVersion": "1.0.0",
    "dockerfile": "Dockerfile",
    "input": "../INPUT_SCHEMA.json",
    "readme": "../README.md",
    "output": "./output_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "views": {
                "tenders": {
                    "title": "Tender Records",
                    "transformation": {
                        "fields": [
                            "source",
                            "keyword",
                            "tenderId",
                            "tenderReferenceNumber",
                            "tenderTitle",
                            "organization",
                            "department",
                            "ministry",
                            "category",
                            "tenderType",
                            "tenderValue",
                            "bidSubmissionStartDate",
                            "bidSubmissionEndDate",
                            "tenderOpenDate",
                            "publishedDate",
                            "closingDate",
                            "bidValidity",
                            "tenderStatus",
                            "city",
                            "state",
                            "location",
                            "eligibilityCriteriaSummary",
                            "emdAmount",
                            "tenderDocumentFee",
                            "tenderUrl",
                            "corrigendumCount",
                            "scrapedAt"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "source": { "label": "Source", "format": "text" },
                            "keyword": { "label": "Keyword", "format": "text" },
                            "tenderId": { "label": "Tender ID", "format": "text" },
                            "tenderReferenceNumber": { "label": "Reference", "format": "text" },
                            "tenderTitle": { "label": "Title", "format": "text" },
                            "organization": { "label": "Organization", "format": "text" },
                            "department": { "label": "Department", "format": "text" },
                            "ministry": { "label": "Ministry", "format": "text" },
                            "category": { "label": "Category", "format": "text" },
                            "tenderType": { "label": "Type", "format": "text" },
                            "tenderValue": { "label": "Value", "format": "number" },
                            "bidSubmissionStartDate": { "label": "Bid Start", "format": "date" },
                            "bidSubmissionEndDate": { "label": "Bid End", "format": "date" },
                            "tenderOpenDate": { "label": "Opening Date", "format": "date" },
                            "publishedDate": { "label": "Published", "format": "date" },
                            "closingDate": { "label": "Closing", "format": "date" },
                            "bidValidity": { "label": "Bid Validity", "format": "text" },
                            "tenderStatus": { "label": "Status", "format": "text" },
                            "city": { "label": "City", "format": "text" },
                            "state": { "label": "State", "format": "text" },
                            "location": { "label": "Location", "format": "text" },
                            "eligibilityCriteriaSummary": { "label": "Eligibility", "format": "text" },
                            "emdAmount": { "label": "EMD", "format": "number" },
                            "tenderDocumentFee": { "label": "Document Fee", "format": "number" },
                            "tenderUrl": { "label": "URL", "format": "link" },
                            "corrigendumCount": { "label": "Corrigenda", "format": "number" },
                            "scrapedAt": { "label": "Scraped At", "format": "date" }
                        }
                    }
                }
            }
        }
    },
    "exampleRunInput": {
        "body": "{\"source\":\"gem\",\"keywords\":[\"laptop\"],\"status\":\"active\",\"maxResults\":1}",
        "contentType": "application/json; charset=utf-8"
    },
    "pricingInfo": {
        "pricingModel": "PAY_PER_EVENT",
        "pricingPerEvent": {
            "actorChargeEvents": {
                "apify-actor-start": {
                    "eventTitle": "Actor Start",
                    "eventDescription": "Automatically charged from allocated memory when a run starts, covering source access and session setup.",
                    "eventPriceUsd": 0.001,
                    "isPrimaryEvent": false,
                    "isOneTimeEvent": true
                },
                "tender-scraped": {
                    "eventTitle": "Tender scraped",
                    "eventDescription": "Charged once for each clean tender listing saved to the dataset.",
                    "eventPriceUsd": 0.003,
                    "isPrimaryEvent": true,
                    "isOneTimeEvent": false
                }
            }
        }
    },
    "defaultRunOptions": {
        "build": "latest",
        "memoryMbytes": 2048,
        "timeoutSecs": 3600
    },
    "minMemoryMbytes": 2048,
    "maxMemoryMbytes": 4096,
    "webScraper": false
}
